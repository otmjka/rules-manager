{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist"
  },
  "include": ["*.ts"],
  "exclude": [                                                                                                                                                                    
         "node_modules",                                                                               
         "archive.log",                                                                                
         "**/*.log.ts",                                                                                
         "**/*.log.md"                                                                                 
      ]
}
